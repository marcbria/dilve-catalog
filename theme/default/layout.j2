<!doctype html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="{{ BASE_PATH }}">
    <title>Catálogo de Libros | {{ ORGANIZATION }}</title>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="css/styles.css" />
    {% block styles %}
    {% if STYLES %}
    <style>{{ STYLES|safe }}</style>
    {% endif %}
    {% endblock %}
    {% block head_extra %}
    {{ HEAD_EXTRA|safe }}
    {% endblock %}
</head>
<body>
    {% block header %}
    {% include "header.html" %}
    {% endblock %}

    <!-- ─── Controles ─── -->
    <div class="controls-bar" id="controlsBar">
        <div class="container controls-inner">
            <div class="search-wrapper">
                <input type="text" id="searchInput" placeholder="Buscar por título, autor o ISBN..." />
                <span class="search-icon">🔍</span>
            </div>
            <button class="hamburger" id="hamburgerBtn" aria-label="Menú filtros">☰</button>
            <div class="filter-group" id="filterGroup">
                <select id="sortSelect">
                    <option value="date-desc" selected>Más recientes</option>
                    <option value="date-asc">Más antiguos</option>
                    <option value="title-asc">Título ▲</option>
                    <option value="title-desc">Título ▼</option>
                    <option value="author-asc">Autor ▲</option>
                    <option value="author-desc">Autor ▼</option>
                </select>
                <select id="langFilter">
                    <option value="all">Todos los idiomas</option>
                    <option value="cat">Catalán</option>
                    <option value="spa">Castellano</option>
                    <option value="eng">Inglés</option>
                </select>
                <select id="formatFilter">
                    <option value="all">Todos los formatos</option>
                    <option value="paper">Papel</option>
                    <option value="digital">Digital</option>
                </select>
                <select id="priceFilter">
                    <option value="all">Todos los tipos de acceso</option>
                    <option value="diamond">Libros en abierto</option>
                    <option value="paid">De pago</option>
                </select>
                <div id="collectionFilterWrapper">
                    <select id="collectionFilter">
                        <option value="all">Todas las colecciones</option>
                    </select>
                </div>
                <button id="resetFilters">Reset</button>
                <span class="results-count" id="resultsCount"></span>
            </div>
        </div>
    </div>

    <!-- ─── Contenido principal ─── -->
    <main class="main-content">
        <div class="container">
            <div class="file-fallback" id="fileFallback">
                <p><strong>⚠️ No se ha podido cargar automáticamente el catálogo.</strong></p>
                <p style="color:#888;">Selecciona el archivo <strong>catalog.csv</strong> desde tu ordenador:</p>
                <input type="file" id="csvFileInput" accept=".csv,.tsv,.txt" />
            </div>
            <div class="collection-intro" id="collectionIntro"></div>
            <div class="books-grid" id="booksGrid">
                <div class="scroll-sentinel" id="scrollSentinel"></div>
                <div class="loading-indicator" id="loadingIndicator">Cargando más libros...</div>
            </div>
            <div class="no-results" id="noResults" style="display:none;">
                <div class="icon"><i class="fa-solid fa-book-skull"></i></div>
                <p>No se han encontrado libros con estos criterios.</p>
                <p style="font-size:0.9rem;color:#888;">Prueba con otros filtros o términos de búsqueda.</p>
            </div>
        </div>
    </main>

    <!-- ─── Modal ─── -->
    <div class="catalog-modal-overlay" id="catalogModalOverlay">
        <div class="catalog-modal" id="catalogModalContent">
            <button class="catalog-modal-close" id="catalogModalClose" title="Cerrar">
                <i class="fa-solid fa-times"></i>
            </button>
            <div class="catalog-modal-body" id="catalogModalBody"></div>
        </div>
    </div>

    {% block footer %}
    {% include "footer.html" %}
    {% endblock %}

    <!-- ─── Módulos JavaScript ─── -->
    <script src="js/theme-config.js"></script>
    <script type="module" src="js/config.js"></script>
    <script type="module" src="js/csvParser.js"></script>
    <script type="module" src="js/bookTransformer.js"></script>
    <script type="module" src="js/collections.js"></script>
    <script type="module" src="js/filters.js"></script>
    <script type="module" src="js/uiRenderer.js"></script>
    <script type="module" src="js/urlManager.js"></script>
    <script type="module" src="js/app.js"></script>
</body>
</html>
