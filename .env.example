# ============================================================
# CONFIGURACIÓN DE DILVE (obligatorio)
# ============================================================

# Usuario y contraseña de acceso a la API de DILVE
# Obtén tus credenciales en: https://www.dilve.es/dilve/acceso.do
DILVE_USER=tu_usuario
DILVE_PASS=tu_contraseña

# Código(s) de la editorial. Varios separados por pipe (|)
# Formato: DLV0000XXXX (con ceros) o solo el número
# Ejemplo: DLV00001234|DLV00005678
EDITORIAL_CODE=DLV00001234

# ============================================================
# CONFIGURACIÓN DE LA DESCARGA (opcional)
# ============================================================

# Tamaño de lote para las peticiones a DILVE (máximo 128)
# Si hay muchos ISBN, se dividen en lotes de este tamaño
# Por defecto: 128
BATCH_SIZE=128

# Códigos de estado activos (lista 64 de ONIX), separados por coma
# Solo se descargarán los productos con estos estados.
# Códigos comunes:
#   04 = Active (disponible)
#   02 = Forthcoming (próxima publicación)
#   13 = Available (disponible)
#   18 = Active (publicado)
# Por defecto: "04,02,13,18"
ACTIVE_STATUS_CODES=04,02,13,18

# ============================================================
# CONFIGURACIÓN DEL CONTENEDOR (opcional)
# ============================================================

# Programación del cron para actualización automática (formato cron)
# El cron ejecutará /app/update.sh a la hora indicada.
# Por defecto: "0 2 * * *" (diario a las 2:00 AM)
# Formato: minuto hora día_mes mes día_semana
CRON_SCHEDULE=0 2 * * *

# Zona horaria del contenedor (para logs y cron)
# Lista de zonas horarias válidas: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Por defecto: "UTC"
# Ejemplos: Europe/Madrid, America/New_York, Asia/Tokyo
TZ=UTC

# Ruta pública si se usa traefik (opcional, por defecto /)
# Si el catálogo está servido en un subdirectorio, indícalo aquí.
# Ejemplo: /llibres/cataleg
BASE_PATH=/

# ============================================================
# CONFIGURACIÓN DEL TEMA (opcional)
# ============================================================

# Nombre de la organización.
ORGANIZATION="Universitat Autònoma de Barcelona"

# Nombre del tema a utilizar.
# Los temas disponibles están en la carpeta theme/
# Por defecto: "default"
THEME=default

# Logo del tema.
# Puede ser:
#   - Una URL externa (ej: https://ejemplo.com/logo.png)
#   - Un nombre de archivo que se buscará en theme/<tema>/img/<nombre>
#   - Si no se define, se usa el logo por defecto del tema (el de la UAB)
# Ejemplo: logo.webp (buscará theme/default/img/logo.webp)
LOGO=logo.webp
